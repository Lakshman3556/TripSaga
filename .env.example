# TripSaga / TripSage AI - Environment Configuration Template

# ------------------------------------------------------------------------------
# LLM Provider Configuration
# ------------------------------------------------------------------------------
# Choose one of: 'gemini', 'groq', or 'ollama'
LLM_PROVIDER=gemini

# ------------------------------------------------------------------------------
# Google Gemini Configuration
# ------------------------------------------------------------------------------
# Get your free Gemini API key from: https://aistudio.google.com/
GEMINI_API_KEY=your_actual_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ------------------------------------------------------------------------------
# Groq Cloud Configuration (Optional)
# ------------------------------------------------------------------------------
# Get your free Groq API key from: https://console.groq.com/
GROQ_API_KEY=your_actual_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# ------------------------------------------------------------------------------
# Local Ollama Configuration (Optional)
# ------------------------------------------------------------------------------
# Used when LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ------------------------------------------------------------------------------
# OpenTripMap API Configuration (Optional)
# ------------------------------------------------------------------------------
# Get your free key from: https://opentripmap.io
OPENTRIPMAP_KEY=your_opentripmap_key_here
